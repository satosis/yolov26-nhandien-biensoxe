# --- Home Assistant ---
HA_INTERNAL_URL=http://192.168.1.x:8123
HA_EXTERNAL_URL=https://ha-gateway.ts.net:8123

# --- Tailscale (chỉ cần nếu dùng profile remote_ha_tailscale) ---
TS_AUTHKEY=
TS_HOSTNAME=ha-gateway
TS_EXTRA_ARGS=--accept-dns=true --accept-routes=true

# --- PostgreSQL ---
POSTGRES_DB=camera_ai
POSTGRES_USER=camera_user
POSTGRES_PASSWORD=password
# psycopg2 connection string (dùng cho SettingsStore)
DATABASE_URL=postgresql://camera_user:password@localhost:5432/camera_ai
