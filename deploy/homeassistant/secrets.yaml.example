# ===== MQTT =====
mqtt_host: mosquitto
mqtt_user: your_mqtt_user
mqtt_password: your_mqtt_password

# ===== Frigate API endpoint =====
frigate_host: http://frigate:5000

# ===== Home Assistant URL + token để gọi API /api/frigate/notifications/... =====
ha_base_url: http://homeassistant:8123
ha_long_lived_access_token: your_home_assistant_llat

# ===== RTSP (nếu cần dùng ở chỗ khác trong HA) =====
rtsp_substream_url: rtsp://user:pass@camera-ip:554/cam/realmonitor?channel=1&subtype=1
rtsp_mainstream_url: rtsp://user:pass@camera-ip:554/cam/realmonitor?channel=1&subtype=0
